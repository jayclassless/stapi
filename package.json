{
  "name": "stapi",
  "version": "0.1.0",
  "private": true,
  "description": "Star Trek: The GraphQL API",
  "license": "MIT",
  "author": "Jason Simeone",
  "main": "index.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit",
    "fullcheck": "pnpm run typecheck && pnpm run lint && pnpm run format && pnpm run test:coverage && pnpm run test:e2e",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:all": "pnpm run test && pnpm run test:e2e"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/platform-express": "^11.1.16",
    "better-sqlite3": "^12.6.2",
    "cookie-parser": "^1.4.7",
    "graphql": "^16.13.1",
    "graphql-sse": "^2.6.0",
    "graphql-ws": "^6.0.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "^11.1.16",
    "@swc/core": "^1.10.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.2",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@apollo/protobufjs",
      "@nestjs/core",
      "@swc/core",
      "better-sqlite3",
      "esbuild"
    ]
  }
}
