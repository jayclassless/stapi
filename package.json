{
  "name": "stapi",
  "version": "0.1.0",
  "private": true,
  "description": "Star Trek: The GraphQL API",
  "license": "MIT",
  "author": "Jason Simeone",
  "main": "index.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit",
    "fullcheck": "pnpm run typecheck && pnpm run lint && pnpm run format"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/platform-express": "^11.1.16",
    "better-sqlite3": "^12.6.2",
    "graphql": "^16.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@apollo/protobufjs",
      "@nestjs/core",
      "better-sqlite3"
    ]
  }
}
