{
  "name": "stapi",
  "version": "0.1.0",
  "private": true,
  "description": "Star Trek: The GraphQL API",
  "license": "MIT",
  "author": "Jason Simeone",
  "type": "module",
  "scripts": {
    "dev": "SWC_NODE_PROJECT=tsconfig.server.json node --watch --import @swc-node/register/esm-register server/server.ts",
    "build": "next build && tsc -p tsconfig.server.json",
    "start": "NODE_ENV=production node dist-server/server.js",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "typecheck": "pnpm run typecheck:server && pnpm run typecheck:client",
    "typecheck:server": "tsc --noEmit -p tsconfig.server.json",
    "typecheck:client": "tsc --noEmit",
    "fullcheck": "pnpm run typecheck && pnpm run lint && pnpm run format && pnpm run test && pnpm run test:e2e",
    "fullcheck:server": "pnpm run typecheck:server && pnpm run lint && pnpm run format && pnpm run test:server:coverage && pnpm run test:server:e2e",
    "fullcheck:client": "pnpm run typecheck:client && pnpm run lint && pnpm run format && pnpm run test:client:coverage",
    "test": "pnpm run test:server && pnpm run test:client",
    "test:e2e": "pnpm run test:server:e2e",
    "test:client": "vitest run --config vitest.client.config.ts",
    "test:client:coverage": "vitest run --config vitest.client.config.ts --coverage",
    "test:server": "vitest run",
    "test:server:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:server:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "graphql": "^16.13.1",
    "graphql-sse": "^2.6.0",
    "graphql-ws": "^6.0.7",
    "morgan": "^1.10.1",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "type-graphql": "2.0.0-rc.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.21",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@apollo/protobufjs",
      "@swc/core",
      "esbuild"
    ]
  }
}
