{
  "name": "stapi",
  "version": "0.1.0",
  "private": true,
  "description": "Star Trek: The GraphQL API",
  "license": "MIT",
  "author": "Jason Simeone",
  "main": "index.js",
  "scripts": {
    "build": "pnpm build:server && pnpm run build:client",
    "build:client": "vite build --config vite.client.config.ts",
    "build:server": "nest build",
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:client": "vite --config vite.client.config.ts",
    "dev:server": "nest start --watch",
    "start": "nest start",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "typecheck": "pnpm run typecheck:server && pnpm run typecheck:client",
    "typecheck:client": "tsc --noEmit --project client/tsconfig.json",
    "typecheck:server": "tsc --noEmit",
    "fullcheck": "pnpm run typecheck && pnpm run lint && pnpm run format && pnpm run test",
    "fullcheck:client": "pnpm run typecheck:client && pnpm run lint && pnpm run format && pnpm run test:client:coverage",
    "fullcheck:server": "pnpm run typecheck:server && pnpm run lint && pnpm run format && pnpm run test:server:coverage && pnpm run test:server:e2e",
    "test": "pnpm run test:server && pnpm run test:client",
    "test:e2e": "pnpm run test:server:e2e",
    "test:client": "vitest run --config vitest.client.config.ts",
    "test:client:coverage": "vitest run --config vitest.client.config.ts --coverage",
    "test:server": "vitest run",
    "test:server:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:server:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/platform-express": "^11.1.17",
    "better-sqlite3": "^12.8.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "graphql": "^16.13.1",
    "graphql-sse": "^2.6.0",
    "graphql-ws": "^6.0.7",
    "morgan": "^1.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "^11.1.17",
    "@swc/core": "^1.15.21",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@apollo/protobufjs",
      "@nestjs/core",
      "@swc/core",
      "better-sqlite3",
      "esbuild"
    ]
  }
}
