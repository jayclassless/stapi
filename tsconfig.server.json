{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "outDir": "dist-server",
    "sourceMap": true,
    "declaration": false
  },
  "include": ["server/**/*"]
}
